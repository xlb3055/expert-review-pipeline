{
  "name": "expert_review_result",
  "description": "专家考核产物评审输出结构：专家能力分（0-10）+ Trace 资产分（0-12）",
  "strict": true,
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "expert_ability": {
        "type": "object",
        "description": "模块A：专家能力分（0-10）",
        "additionalProperties": false,
        "properties": {
          "task_complexity": {
            "type": "object",
            "description": "任务复杂度 (0-3)",
            "additionalProperties": false,
            "properties": {
              "score": { "type": "integer", "description": "分数 (0-3)" },
              "evidence": { "type": "string", "description": "评分证据，引用 trace 或任务描述中的具体内容，中文" },
              "suggestion": { "type": "string", "description": "针对该维度扣分点的优化建议，满分可写'无，当前表现优秀'，中文" }
            },
            "required": ["score", "evidence", "suggestion"]
          },
          "iteration_quality": {
            "type": "object",
            "description": "迭代质量 (0-3)",
            "additionalProperties": false,
            "properties": {
              "score": { "type": "integer", "description": "分数 (0-3)" },
              "evidence": { "type": "string", "description": "评分证据，引用 trace 中专家的交互行为，中文" },
              "suggestion": { "type": "string", "description": "针对该维度扣分点的优化建议，满分可写'无，当前表现优秀'，中文" }
            },
            "required": ["score", "evidence", "suggestion"]
          },
          "professional_judgment": {
            "type": "object",
            "description": "专业判断 (0-4)",
            "additionalProperties": false,
            "properties": {
              "score": { "type": "integer", "description": "分数 (0-4)" },
              "evidence": { "type": "string", "description": "评分证据，说明产出如何体现专业性，中文" },
              "suggestion": { "type": "string", "description": "针对该维度扣分点的优化建议，满分可写'无，当前表现优秀'，中文" }
            },
            "required": ["score", "evidence", "suggestion"]
          },
          "total": {
            "type": "integer",
            "description": "专家能力总分 (0-10)，为三个维度分数之和"
          }
        },
        "required": ["task_complexity", "iteration_quality", "professional_judgment", "total"]
      },
      "trace_asset": {
        "type": "object",
        "description": "模块B：Trace 资产分（0-12）",
        "additionalProperties": false,
        "properties": {
          "authenticity": {
            "type": "object",
            "description": "真实性 (0-2)",
            "additionalProperties": false,
            "properties": {
              "score": { "type": "integer", "description": "分数 (0-2)" },
              "evidence": { "type": "string", "description": "评分证据，中文" },
              "suggestion": { "type": "string", "description": "针对该维度扣分点的优化建议，满分可写'无，当前表现优秀'，中文" }
            },
            "required": ["score", "evidence", "suggestion"]
          },
          "info_density": {
            "type": "object",
            "description": "信息密度 (0-2)",
            "additionalProperties": false,
            "properties": {
              "score": { "type": "integer", "description": "分数 (0-2)" },
              "evidence": { "type": "string", "description": "评分证据，中文" },
              "suggestion": { "type": "string", "description": "针对该维度扣分点的优化建议，满分可写'无，当前表现优秀'，中文" }
            },
            "required": ["score", "evidence", "suggestion"]
          },
          "tool_loop": {
            "type": "object",
            "description": "工具闭环 (0-2)",
            "additionalProperties": false,
            "properties": {
              "score": { "type": "integer", "description": "分数 (0-2)" },
              "evidence": { "type": "string", "description": "评分证据，中文" },
              "suggestion": { "type": "string", "description": "针对该维度扣分点的优化建议，满分可写'无，当前表现优秀'，中文" }
            },
            "required": ["score", "evidence", "suggestion"]
          },
          "correction_value": {
            "type": "object",
            "description": "纠偏价值 (0-2)",
            "additionalProperties": false,
            "properties": {
              "score": { "type": "integer", "description": "分数 (0-2)" },
              "evidence": { "type": "string", "description": "评分证据，中文" },
              "suggestion": { "type": "string", "description": "针对该维度扣分点的优化建议，满分可写'无，当前表现优秀'，中文" }
            },
            "required": ["score", "evidence", "suggestion"]
          },
          "verification_loop": {
            "type": "object",
            "description": "验证闭环 (0-2)",
            "additionalProperties": false,
            "properties": {
              "score": { "type": "integer", "description": "分数 (0-2)" },
              "evidence": { "type": "string", "description": "评分证据，中文" },
              "suggestion": { "type": "string", "description": "针对该维度扣分点的优化建议，满分可写'无，当前表现优秀'，中文" }
            },
            "required": ["score", "evidence", "suggestion"]
          },
          "compliance": {
            "type": "object",
            "description": "合规可用性 (0-2)",
            "additionalProperties": false,
            "properties": {
              "score": { "type": "integer", "description": "分数 (0-2)" },
              "evidence": { "type": "string", "description": "评分证据，中文" },
              "suggestion": { "type": "string", "description": "针对该维度扣分点的优化建议，满分可写'无，当前表现优秀'，中文" }
            },
            "required": ["score", "evidence", "suggestion"]
          },
          "total": {
            "type": "integer",
            "description": "Trace 资产总分 (0-12)，为六个维度分数之和"
          }
        },
        "required": ["authenticity", "info_density", "tool_loop", "correction_value", "verification_loop", "compliance", "total"]
      },
      "overall_assessment": {
        "type": "string",
        "description": "1-3句话简要总评，概括核心优势与主要不足，中文输出。"
      },
      "trace_highlights": {
        "type": "array",
        "description": "Trace 亮点，1-3 个值得关注的交互片段描述",
        "items": { "type": "string" }
      }
    },
    "required": ["expert_ability", "trace_asset", "overall_assessment", "trace_highlights"]
  }
}
