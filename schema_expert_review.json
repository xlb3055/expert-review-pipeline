{
  "name": "expert_review_result",
  "description": "专家考核产物评审输出结构，含 3 个维度评分、总分、整体评估和 trace 亮点",
  "parameters": {
    "type": "object",
    "properties": {
      "expert_review_result": {
        "type": "object",
        "description": "专家考核产物评审完整结果",
        "properties": {
          "task_complexity": {
            "type": "object",
            "description": "维度1：任务复杂度 (0-3分)",
            "properties": {
              "score": {
                "type": "integer",
                "description": "分数 (0-3)",
                "minimum": 0,
                "maximum": 3
              },
              "evidence": {
                "type": "string",
                "description": "评分证据，引用 trace 或任务描述中的具体内容，中文"
              }
            },
            "required": ["score", "evidence"]
          },
          "iteration_quality": {
            "type": "object",
            "description": "维度2：迭代质量 (0-3分)",
            "properties": {
              "score": {
                "type": "integer",
                "description": "分数 (0-3)",
                "minimum": 0,
                "maximum": 3
              },
              "evidence": {
                "type": "string",
                "description": "评分证据，引用 trace 中专家的交互行为，中文"
              }
            },
            "required": ["score", "evidence"]
          },
          "professional_judgment": {
            "type": "object",
            "description": "维度3：专业判断 (0-4分)",
            "properties": {
              "score": {
                "type": "integer",
                "description": "分数 (0-4)",
                "minimum": 0,
                "maximum": 4
              },
              "evidence": {
                "type": "string",
                "description": "评分证据，说明产出如何体现专业性，中文"
              }
            },
            "required": ["score", "evidence"]
          },
          "total_score": {
            "type": "integer",
            "description": "总分 (0-10)，为三个维度分数之和",
            "minimum": 0,
            "maximum": 10
          },
          "overall_assessment": {
            "type": "string",
            "description": "整体评估，2-5 句话中文概括"
          },
          "trace_highlights": {
            "type": "array",
            "description": "Trace 亮点，1-3 个值得关注的交互片段描述",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "task_complexity",
          "iteration_quality",
          "professional_judgment",
          "total_score",
          "overall_assessment",
          "trace_highlights"
        ]
      }
    },
    "required": ["expert_review_result"]
  }
}
